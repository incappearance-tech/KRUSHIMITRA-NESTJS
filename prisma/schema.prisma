generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String              @id @default(uuid())
  phoneNumber            String              @unique
  name                   String?
  role                   UserRole            @default(GUEST)
  locationLat            Float?
  locationLng            Float?
  preferredLanguage      String              @default("en")
  isVerified             Boolean             @default(false)
  fcmToken               String?
  deviceOS               String?
  privacyConsent         Boolean             @default(false)
  consentTimestamp       DateTime?
  deletedAt              DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  farmerId               String?
  profileImage           String?
  auditLogs              AuditLog[]
  callsOutgoing          CallLog[]           @relation("CallerLogs")
  callsIncoming          CallLog[]           @relation("ReceiverLogs")
  farmerMaterials        FarmerMaterial[]    @relation("FarmerMaterials")
  labourBookings         LabourBooking[]     @relation("FarmerBookings")
  labourProfile          LabourProfile?
  listings               Machine[]
  notifications          Notification[]
  ordersAsBuyer          Order[]             @relation("BuyerOrders")
  ordersAsSeller         Order[]             @relation("SellerOrders")
  payments               Payment[]
  borrowerRentalRequests RentalRequest[]     @relation("BorrowerRentalRequests")
  ownerRentalRequests    RentalRequest[]     @relation("OwnerRentalRequests")
  subscriptions          Subscription[]
  transportRequests      TransportRequest[]  @relation("FarmerRequests")
  transportTrips         TransportTrip[]     @relation("FarmerTrips")
  transporterProfile     TransporterProfile?

  @@index([role])
  @@index([isVerified])
  @@index([role, isVerified])
  @@index([createdAt])
  @@index([phoneNumber, role])
}

model LabourProfile {
  id             String          @id @default(uuid())
  userId         String          @unique
  skills         String[]
  experience     String?
  pricePerDay    Decimal         @db.Decimal(10, 2)
  workPreference String          @default("Day")
  isAvailable    Boolean         @default(true)
  rating         Float           @default(0)
  jobsCompleted  Int             @default(0)
  callsReceived  Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  lat            Float?
  lng            Float?
  bookings       LabourBooking[] @relation("LabourBookings")
  user           User            @relation(fields: [userId], references: [id])

  @@index([isAvailable])
  @@index([rating])
  @@index([isAvailable, rating])
}

model TransporterProfile {
  id              String          @id @default(uuid())
  userId          String          @unique
  businessName    String?
  operatingRadius Int             @default(50)
  experience      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  lat             Float?
  lng             Float?
  trips           TransportTrip[]
  user            User            @relation(fields: [userId], references: [id])
  vehicles        Vehicle[]

  @@index([lat, lng])
}

model TransportTrip {
  id             String             @id @default(uuid())
  transporterId  String
  farmerId       String?
  farmerName     String
  farmerPhone    String
  pickupLocation String
  dropLocation   String
  loadType       String?
  vehicleType    String
  date           DateTime
  status         String             @default("pending")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  weight         String?
  farmer         User?              @relation("FarmerTrips", fields: [farmerId], references: [id])
  transporter    TransporterProfile @relation(fields: [transporterId], references: [id])

  @@index([transporterId])
  @@index([farmerId])
  @@index([status, createdAt])
  @@index([date])
  @@index([transporterId, status, createdAt])
  @@index([farmerId, status, createdAt])
}

model Vehicle {
  id              String                @id @default(uuid())
  transporterId   String
  type            String
  model           String
  numberPlate     String?
  capacity        String?
  ratePerKm       Decimal?              @db.Decimal(10, 2)
  isAvailable     Boolean               @default(true)
  images          String[]
  driverName      String?
  driverPhone     String?
  driverLicense   String?
  plan            String?
  expiryDate      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  operatingArea   String?
  rating          Float                 @default(0)
  tripCount       Int                   @default(0)
  locationLat     Float?
  locationLng     Float?
  operatingRadius Int?
  drivers         Driver[]
  subscriptions   Subscription[]
  requests        TransportRequest[]
  transporter     TransporterProfile    @relation(fields: [transporterId], references: [id])
  availability    VehicleAvailability[]

  @@index([transporterId])
  @@index([type, isAvailable])
  @@index([locationLat, locationLng])
  @@index([expiryDate])
}

model Driver {
  id         String   @id @default(uuid())
  vehicleId  String
  name       String
  mobile     String
  license    String?
  experience String?
  photo      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
}

model VehicleAvailability {
  id        String            @id @default(uuid())
  vehicleId String
  date      DateTime
  state     AvailabilityState @default(AVAILABLE)
  note      String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  vehicle   Vehicle           @relation(fields: [vehicleId], references: [id])

  @@unique([vehicleId, date])
  @@index([vehicleId])
  @@index([date])
  @@index([vehicleId, date])
}

model TransportRequest {
  id                 String                 @id @default(uuid())
  farmerId           String
  vehicleId          String
  transporterId      String
  pickup             String
  drop               String
  crop               String?
  quantity           String?
  requiredDate       DateTime
  status             TransportRequestStatus @default(SENT)
  rejectedAt         DateTime?
  suggestedDate      DateTime?
  cancellationReason String?
  cancelledById      String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  farmer             User                   @relation("FarmerRequests", fields: [farmerId], references: [id])
  vehicle            Vehicle                @relation(fields: [vehicleId], references: [id])

  @@index([farmerId])
  @@index([vehicleId])
  @@index([transporterId])
  @@index([status, createdAt])
  @@index([farmerId, status, createdAt])
  @@index([transporterId, status, createdAt])
  @@index([vehicleId, requiredDate])
  @@index([farmerId, vehicleId, status])
  @@index([transporterId, status])
}

model MachineCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  icon      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Machine {
  id             String          @id @default(uuid())
  ownerId        String
  category       String
  brand          String
  model          String
  yearOfPurchase Int
  listingType    ListingType     @default(SELL)
  price          Decimal         @db.Decimal(10, 2)
  images         String[]
  status         ListingStatus   @default(AVAILABLE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  lat            Float?
  lng            Float?
  plan           String?
  planExpiresAt  DateTime?
  pricingUnit    String          @default("PER_HOUR")
  isNegotiable   Boolean         @default(false)
  busyDates      DateTime[]
  owner          User            @relation(fields: [ownerId], references: [id])
  orders         Order[]
  rentalRequests RentalRequest[]

  @@index([status])
  @@index([listingType])
  @@index([category])
  @@index([status, listingType])
  @@index([category, status])
  @@index([price])
  @@index([createdAt])
  @@index([ownerId])
}

model RentalRequest {
  id           String              @id @default(uuid())
  machineId    String
  borrowerId   String
  ownerId      String
  startDate    DateTime
  numberOfDays Int
  pricePerDay  Decimal             @db.Decimal(10, 2)
  totalPrice   Decimal             @db.Decimal(10, 2)
  status       RentalRequestStatus @default(PENDING)
  note         String?
  rejectReason String?
  respondedAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  borrower     User                @relation("BorrowerRentalRequests", fields: [borrowerId], references: [id])
  machine      Machine             @relation(fields: [machineId], references: [id], onDelete: Cascade)
  owner        User                @relation("OwnerRentalRequests", fields: [ownerId], references: [id])

  @@index([machineId, status])
  @@index([borrowerId, status])
  @@index([ownerId, status])
  @@index([status, createdAt])
  @@index([createdAt])
}

model Order {
  id                   String   @id @default(uuid())
  buyerId              String
  sellerId             String
  machineId            String?
  amount               Decimal  @db.Decimal(10, 2)
  paymentStatus        String   @default("PENDING")
  gatewayTransactionId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  buyer                User     @relation("BuyerOrders", fields: [buyerId], references: [id])
  machine              Machine? @relation(fields: [machineId], references: [id])
  seller               User     @relation("SellerOrders", fields: [sellerId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  resource  String
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model LabourBooking {
  id           String        @id @default(uuid())
  farmerId     String
  labourId     String
  taskType     String
  date         DateTime
  numberOfDays Int           @default(1)
  location     String
  workers      Int           @default(1)
  description  String?
  status       String        @default("pending")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  farmer       User          @relation("FarmerBookings", fields: [farmerId], references: [id])
  labour       LabourProfile @relation("LabourBookings", fields: [labourId], references: [id])

  @@index([farmerId])
  @@index([labourId])
  @@index([status])
  @@index([labourId, status])
  @@index([farmerId, status])
  @@index([labourId, status, createdAt])
}

model Payment {
  id                String        @id @default(uuid())
  userId            String
  type              String
  amount            Decimal       @db.Decimal(10, 2)
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?
  status            String        @default("PENDING")
  entityId          String?
  createdAt         DateTime      @default(now())
  description       String?
  metadata          Json?
  updatedAt         DateTime      @default(now()) @updatedAt
  upiMethod         String?
  upiTxnRef         String?
  entityType        String?       @default("MACHINE")
  paymentMethod     String?       @default("UPI")
  refundAmount      Decimal?      @db.Decimal(10, 2)
  refundReason      String?
  refundedAt        DateTime?
  role              String        @default("FARMER")
  feature           String?
  planTier          String?
  user              User          @relation(fields: [userId], references: [id])
  subscription      Subscription?

  @@index([userId])
  @@index([userId, role])
  @@index([userId, type])
  @@index([status])
  @@index([type])
  @@index([role])
  @@index([entityId, entityType])
  @@index([createdAt])
  @@index([razorpayOrderId])
  @@index([userId, status])
  @@index([type, status])
  @@index([status, createdAt])
}

model Subscription {
  id               String   @id @default(uuid())
  vehicleId        String?
  paymentId        String   @unique
  plan             String
  startDate        DateTime
  endDate          DateTime
  renewalCount     Int      @default(0)
  expiryNotified   Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  autoRenew        Boolean  @default(false)
  entityId         String
  entityType       String   @default("VEHICLE")
  subscriptionType String   @default("VEHICLE_PLAN")
  userId           String
  payment          Payment  @relation(fields: [paymentId], references: [id])
  user             User     @relation(fields: [userId], references: [id])
  vehicle          Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([userId])
  @@index([entityId, entityType])
  @@index([endDate])
  @@index([subscriptionType])
  @@index([expiryNotified, endDate])
  @@index([userId, subscriptionType])
  @@index([vehicleId])
}

model WebhookLog {
  id        String   @id @default(uuid())
  event     String
  orderId   String?
  paymentId String?
  payload   Json
  processed Boolean  @default(false)
  errorMsg  String?
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([event])
  @@index([processed])
  @@index([createdAt])
}

model CallLog {
  id              String   @id @default(uuid())
  callerId        String
  receiverId      String
  bookingId       String?
  bookingType     String?
  exotelCallId    String?
  durationSeconds Int      @default(0)
  status          String   @default("initiated")
  createdAt       DateTime @default(now())
  caller          User     @relation("CallerLogs", fields: [callerId], references: [id])
  receiver        User     @relation("ReceiverLogs", fields: [receiverId], references: [id])

  @@index([callerId])
  @@index([receiverId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
}

model FeeConfig {
  id          String   @id @default(uuid())
  feature     String   @unique
  amountPaise Int
  isActive    Boolean  @default(true)
  label       String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model FarmerMaterial {
  id           String   @id @default(uuid())
  farmerId     String
  materialName String
  photoUrl     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expiresAt    DateTime @default(now())
  farmer       User     @relation("FarmerMaterials", fields: [farmerId], references: [id])

  @@index([farmerId])
  @@index([createdAt])
  @@index([expiresAt])
}

enum UserRole {
  FARMER
  LABOUR
  TRANSPORTER
  GUEST
}

enum ListingType {
  SELL
  RENT
}

enum AvailabilityState {
  AVAILABLE
  BUSY
  MAINTENANCE
  DRIVER_UNAVAILABLE
}

enum TransportRequestStatus {
  SENT
  ACCEPTED
  REJECTED
  SCHEDULED
  COMPLETED
  CANCELLED
  AWAITING_APPROVAL
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  CALL_LOG
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ListingStatus {
  AVAILABLE
  SOLD
  IN_RENT
  WAITING_PAYMENT
}

enum RentalRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}
